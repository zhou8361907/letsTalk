{
  "name": "lets-talk",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @lets-talk/web dev",
    "build": "pnpm -r build",
    "smoke": "pnpm --filter @lets-talk/agent-runtime smoke",
    "minimal": "pnpm --filter @lets-talk/agent-runtime minimal",
    "lint": "pnpm -r lint",
    "sync-menu": "node scripts/sync-menu-map.mjs all",
    "sessions:import": "pnpm --filter @lets-talk/conversation import-sessions"
  },
  "devDependencies": {
    "dotenv": "^16.4.0",
    "mysql2": "^3.14.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
