# DeepSeek 密钥（必填）
LLM_API_KEY=

# letsTalk 运行根目录（必填，填本仓库绝对路径）
WORKSPACE_ROOT=/Users/zs/IdeaProjects/work/letsTalk

# 待分析代码放在运行根下的子目录（相对名或绝对路径均可）
FRONTEND_ROOT=workFront
BACKEND_ROOT=workBack

# 网页端口
PORT=3000

# 菜单库（可选，用于生成 menu-map.json；勿提交真实密码）
# MENU_DB_HOST=10.16.28.136
# MENU_DB_PORT=32106
# MENU_DB_USER=root
# MENU_DB_PASSWORD=
# MENU_DB_NAME=mifc
# MENU_USER_SYS_ID=672

# 调试：清单更新 + 每轮完整上下文/响应 → .agent/debug/{sessionId}/
# LETS_TALK_DEBUG=1

# Skills（默认开启）：.agent/skills/ 渐进披露 + skill_manage
# LETS_TALK_SKILLS=0

# 会话冷存储 state.db（默认开启 SQLite 双写；0=纯 JSON）
# LETS_TALK_SESSION_DB=1
# LETS_TALK_SESSION_DB_PATH=

# 用户问「上次/上周聊过」时自动 FTS 召回进 user prefix（默认开启；0=关闭）
# LETS_TALK_EPISODIC_PREFETCH=1

# 后台 self-improvement review（memory + skill_manage，每 N 轮 user turn）
# LETS_TALK_SELF_IMPROVE_NUDGE_INTERVAL=10
# 兼容旧名：LETS_TALK_MEMORY_NUDGE_INTERVAL

# 上下文保底（DeepSeek 1M：日常很少触顶，仅极端会话提醒）
# 自定义工具单次返回字符软顶（默认 24576）
# LETS_TALK_TOOL_OUTPUT_CHAR_LIMIT=24576
# 占用阈值 percent：50 提示变慢/变贵，90 自动 compact 压缩较早对话
# LETS_TALK_CONTEXT_WARN_PERCENT=50
# LETS_TALK_CONTEXT_CRITICAL_PERCENT=90
