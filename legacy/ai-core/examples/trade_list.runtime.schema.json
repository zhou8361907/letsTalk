          "key": "query",
          "label": "Query",
          "action_type": "custom",
          "scope": "page",
          "visible_when": null,
          "disabled_when": null,
          "api_name": null
        },
        {
          "key": "reset",
          "label": "Reset",
          "action_type": "custom",
          "scope": "page",
          "visible_when": null,
          "disabled_when": null,
          "api_name": null
        }
      ]
    },
    {
