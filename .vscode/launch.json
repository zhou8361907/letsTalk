{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "letsTalk: Next 服务端 (推荐)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "next", "dev", "--port", "3000"],
      "cwd": "${workspaceFolder}/apps/web",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "skipFiles": ["<node_internals>/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/web/.next/**/*.js",
        "${workspaceFolder}/packages/**/dist/**/*.js"
      ],
      "preLaunchTask": "letsTalk: build packages"
    },
    {
      "name": "letsTalk: Next 全栈调试",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "next", "dev", "--port", "3000"],
      "cwd": "${workspaceFolder}/apps/web",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "skipFiles": ["<node_internals>/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/web/.next/**/*.js",
        "${workspaceFolder}/packages/**/dist/**/*.js"
      ],
      "preLaunchTask": "letsTalk: build packages",
      "serverReadyAction": {
        "pattern": "- Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "letsTalk: 仅终端测 Pi (minimal)",
      "type": "node",
      "request": "launch",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceFolder}/packages/agent-runtime/scripts/minimal.ts",
      "cwd": "${workspaceFolder}/packages/agent-runtime",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "letsTalk: 附加到 Next (9229)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/web/.next/**/*.js",
        "${workspaceFolder}/packages/**/dist/**/*.js"
      ]
    }
  ]
}
